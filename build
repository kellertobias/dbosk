#!/bin/bash
# Usage:
#   ./build                  debug build
#   ./build archive          release build + dist/dbOSK.app (via Scripts/make-app.sh)
#   ./build archive install  release build, then install dbOSK.app to ~/Applications
#   ./build open             debug build, kill running instances, launch a fresh one
#
# Bundle assembly (Info.plist, icon, codesign) lives in Scripts/make-app.sh —
# the single source of truth — so the installed app and the distributed app
# are byte-for-byte the same bundle.
set -euo pipefail
cd "$(dirname "$0")"

APP_NAME="dbOSK"
INSTALL_DIR="$HOME/Applications"

mode="${1:-debug}"
action="${2:-}"

if [[ "$mode" == "archive" ]]; then
    Scripts/make-app.sh
    if [[ "$action" == "install" ]]; then
        APP_BUNDLE="$INSTALL_DIR/$APP_NAME.app"
        mkdir -p "$INSTALL_DIR"
        rm -rf "$APP_BUNDLE"
        cp -R "dist/$APP_NAME.app" "$APP_BUNDLE"
        codesign --verify --deep --strict "$APP_BUNDLE"
        echo "Installed $APP_BUNDLE"
    fi
    exit 0
fi

swift build
BIN_PATH=".build/debug/$APP_NAME"

if [[ "$mode" == "open" ]]; then
    pkill -f "$INSTALL_DIR/$APP_NAME.app/Contents/MacOS/$APP_NAME" 2>/dev/null || true
    pkill -f "/$APP_NAME$" 2>/dev/null || true
    sleep 0.5

    nohup "$BIN_PATH" >/tmp/"$APP_NAME".log 2>&1 &
    disown
    echo "Started $APP_NAME (pid $!)"
fi
